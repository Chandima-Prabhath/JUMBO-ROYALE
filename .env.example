# ===========================================================================
# Jumbo Royale - Environment Variables
# Copy this file to `.env` and customize as needed.
# All variables are OPTIONAL — defaults work for local development.
# ===========================================================================

# --- Next.js Web App (frontend) ---
# Port the Next.js dev/prod server listens on. Default: 3000
PORT=3000

# --- Game Service (Socket.IO realtime server) ---
# Port the Socket.IO game service listens on. Default: 3003
GAME_SERVICE_PORT=3003

# --- Database (Prisma) ---
# SQLite (default, zero-config, file-based). Great for self-hosting single instance.
DATABASE_URL=file:./db/jumbo.db

# For Postgres (recommended for production multi-instance):
# DATABASE_URL=postgresql://user:password@localhost:5432/jumbo_royale

# --- CLIENT-SIDE: Socket.IO connection ---
# All NEXT_PUBLIC_* vars are exposed to the browser.

# Option A: Tell the client exactly where the Socket.IO server lives.
# Use this if your socket server runs on a different host/port than the web app.
# Examples:
#   NEXT_PUBLIC_SOCKET_URL=https://sockets.example.com  (separate domain)
#   NEXT_PUBLIC_SOCKET_URL=http://localhost:3003        (local dev, separate port)
# NEXT_PUBLIC_SOCKET_URL=

# Option B: Same host, different port (auto-built from window.location).
# Useful for dev where you want to test sockets on a different port.
# NEXT_PUBLIC_SOCKET_PORT=3003

# Option C: Use the dev sandbox's Caddy gateway (XTransformPort query).
# Set to 'true' ONLY if you're running inside the Z.ai dev sandbox.
# Default: false
# NEXT_PUBLIC_USE_GATEWAY_QUERY=false
